{
  "name": "conexion-bolivia-visas",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "generate:og": "node scripts/generate-og-image.mjs",
    "sync:reviews": "node --env-file-if-exists=.env scripts/sync-google-reviews.mjs",
    "sync:visa-groups": "node --env-file-if-exists=.env scripts/sync-visa-groups.mjs",
    "export:visa-groups-csv": "node scripts/export-visa-groups-csv.mjs",
    "seed:visa-groups-full": "node scripts/seed-visa-groups-full.mjs && node scripts/export-visa-groups-csv.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "astro": "^5.7.10"
  }
}
