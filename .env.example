# Google Places API (New) + Cloud Translation API — free tier covers weekly syncs.
# https://console.cloud.google.com/google/maps-apis/
# Enable: Places API (New) and Cloud Translation API on the same project.
GOOGLE_PLACES_API_KEY=

# Optional: override the text search query used to find the business Place ID
# GOOGLE_PLACE_QUERY=VISAS BOLIVIA EN CUSCO CONEXION BOLIVIA, Cusco Peru

# Google Analytics 4 — create at https://analytics.google.com/
PUBLIC_GA_MEASUREMENT_ID=

# Plantilla CSV: scripts/visa-groups-sheet-template.csv (encabezados en español)
# Instrucciones para Isabel: scripts/INSTRUCCIONES-LISTA-VISAS.txt
# VISA_GROUPS_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv&gid=0

