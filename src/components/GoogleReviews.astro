---
import type { Locale } from "../i18n/config";
import { getReviewText, type GoogleReviewsData } from "../data/reviews.types";
import { isReviewTranslated } from "../data/review-locales";
import type { ReviewsCopy } from "../i18n/reviews-translations";

interface Props {
  locale: Locale;
  copy: ReviewsCopy;
  data: GoogleReviewsData;
}

const { locale, copy, data } = Astro.props;
const { rating, totalCount, mapsUrl, reviews } = data;

if (reviews.length === 0) {
  return null;
}

const ratingDisplay = rating > 0 ? rating.toFixed(1) : "5.0";
const fullStars = Math.round(rating > 0 ? rating : 5);
---

<section class="section reviews-section" aria-labelledby="reviews-heading">
  <div class="container">
    <div class="reviews-header">
      <div class="reviews-score" aria-label={`${ratingDisplay} out of 5, ${totalCount} ${copy.reviewsLabel} ${copy.onGoogle}`}>
        <span class="reviews-score-value" aria-hidden="true">{ratingDisplay}</span>
        <div class="reviews-score-meta">
          <div class="reviews-stars" aria-hidden="true">
            {Array.from({ length: 5 }, (_, i) => (
              <span class:list={["star", { "star--filled": i < fullStars }]}>★</span>
            ))}
          </div>
          <p class="reviews-score-count">
            {totalCount > 0 ? (
              <>
                <strong>{totalCount.toLocaleString()}</strong> {copy.reviewsLabel} {copy.onGoogle}
              </>
            ) : (
              copy.onGoogle
            )}
          </p>
        </div>
      </div>

      <div class="reviews-intro">
        <h2 id="reviews-heading">{copy.title}</h2>
        <p class="lead">{copy.subtitle}</p>
      </div>
    </div>

    <div class="reviews-carousel" data-reviews-carousel>
      <button
        type="button"
        class="reviews-nav reviews-nav--prev"
        aria-label={copy.prev}
        data-reviews-prev
      >
        ‹
      </button>

      <div class="reviews-viewport">
        <ul class="reviews-track" data-reviews-track>
          {reviews.map((review) => (
            <li class="reviews-card">
              <article class="review-card-inner">
                <header class="review-card-top">
                  <div class="review-author">
                    {review.photoUrl ? (
                      <img
                        class="review-avatar"
                        src={review.photoUrl}
                        alt=""
                        width="44"
                        height="44"
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <span class="review-avatar review-avatar--fallback" aria-hidden="true">
                        {review.author.charAt(0).toUpperCase()}
                      </span>
                    )}
                    <div>
                      <p class="review-author-name">{review.author}</p>
                      {review.relativeTime && (
                        <p class="review-time">{review.relativeTime}</p>
                      )}
                    </div>
                  </div>
                  <div class="review-stars" aria-label="5 out of 5">
                    {Array.from({ length: 5 }, () => (
                      <span class="star star--filled" aria-hidden="true">★</span>
                    ))}
                  </div>
                </header>

                <blockquote class="review-text" lang={locale}>
                  <p>{getReviewText(review, locale)}</p>
                </blockquote>

                <footer class="review-footer">
                  {isReviewTranslated(review.sourceLanguage, locale) && (
                    <p class="review-translated-note">{copy.translatedNote}</p>
                  )}
                  <span class="review-verified">
                    <svg class="google-g" viewBox="0 0 24 24" aria-hidden="true" width="16" height="16">
                      <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
                      <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                      <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
                      <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                    </svg>
                    {copy.verified}
                  </span>
                </footer>
              </article>
            </li>
          ))}
        </ul>
      </div>

      <button
        type="button"
        class="reviews-nav reviews-nav--next"
        aria-label={copy.next}
        data-reviews-next
      >
        ›
      </button>
    </div>

    <p class="reviews-cta-wrap">
      <a class="button button-secondary reviews-cta" href={mapsUrl} target="_blank" rel="noopener noreferrer">
        {copy.seeAll} →
      </a>
    </p>
  </div>
</section>

<script>
  function initReviewsCarousel(root: HTMLElement) {
    const track = root.querySelector<HTMLElement>("[data-reviews-track]");
    const cards = root.querySelectorAll<HTMLElement>(".reviews-card");
    const prev = root.querySelector<HTMLButtonElement>("[data-reviews-prev]");
    const next = root.querySelector<HTMLButtonElement>("[data-reviews-next]");

    if (!track || cards.length <= 1) {
      prev?.setAttribute("hidden", "");
      next?.setAttribute("hidden", "");
      return;
    }

    let index = 0;
    let timer: ReturnType<typeof setInterval> | undefined;
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const goTo = (nextIndex: number) => {
      index = (nextIndex + cards.length) % cards.length;
      const card = cards[index];
      track.scrollTo({ left: card.offsetLeft, behavior: reducedMotion ? "auto" : "smooth" });
    };

    const restartTimer = () => {
      if (reducedMotion) return;
      if (timer) clearInterval(timer);
      timer = setInterval(() => goTo(index + 1), 6000);
    };

    prev?.addEventListener("click", () => {
      goTo(index - 1);
      restartTimer();
    });

    next?.addEventListener("click", () => {
      goTo(index + 1);
      restartTimer();
    });

    restartTimer();

    root.addEventListener("mouseenter", () => {
      if (timer) clearInterval(timer);
    });

    root.addEventListener("mouseleave", restartTimer);
  }

  document.querySelectorAll<HTMLElement>("[data-reviews-carousel]").forEach(initReviewsCarousel);
</script>

<style>
  .reviews-section {
    background: var(--surface);
    border-block: 1px solid var(--border);
  }

  .reviews-header {
    display: grid;
    gap: 1.5rem;
    align-items: center;
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .reviews-header {
      grid-template-columns: auto 1fr;
      gap: 2.5rem;
    }
  }

  .reviews-score {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-radius: 1rem;
    background: linear-gradient(135deg, var(--brand-pale), #fff);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    width: fit-content;
  }

  .reviews-score-value {
    font-size: clamp(2.5rem, 5vw, 3.25rem);
    font-weight: 800;
    line-height: 1;
    color: var(--brand-dark);
  }

  .reviews-score-count {
    margin: 0.35rem 0 0;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .reviews-score-count strong {
    color: var(--brand-dark);
  }

  .reviews-intro h2 {
    margin-top: 0;
  }

  .reviews-intro .lead {
    margin-bottom: 0;
  }

  .reviews-stars,
  .review-stars {
    display: flex;
    gap: 0.1rem;
  }

  .star {
    color: #cbd5e1;
    font-size: 1rem;
    line-height: 1;
  }

  .star--filled {
    color: #f59e0b;
  }

  .reviews-carousel {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.75rem;
    align-items: center;
  }

  .reviews-viewport {
    overflow: hidden;
    min-width: 0;
  }

  .reviews-track {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    list-style: none;
    margin: 0;
    padding: 0.25rem 0 0.75rem;
    scrollbar-width: none;
  }

  .reviews-track::-webkit-scrollbar {
    display: none;
  }

  .reviews-card {
    flex: 0 0 min(100%, 360px);
    scroll-snap-align: start;
  }

  @media (min-width: 768px) {
    .reviews-card {
      flex-basis: calc((100% - 1rem) / 2);
    }
  }

  @media (min-width: 1024px) {
    .reviews-card {
      flex-basis: calc((100% - 2rem) / 3);
    }
  }

  .review-card-inner {
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.25rem;
    border-radius: 1rem;
    border: 1px solid var(--border);
    background: var(--bg);
    box-shadow: var(--shadow);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .review-card-inner:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 34px rgba(13, 43, 69, 0.12);
  }

  .review-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .review-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  .review-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 2px solid #fff;
    box-shadow: 0 2px 8px rgba(13, 43, 69, 0.12);
  }

  .review-avatar--fallback {
    display: grid;
    place-items: center;
    background: var(--brand);
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
  }

  .review-author-name {
    margin: 0;
    font-weight: 700;
    color: var(--brand-dark);
    line-height: 1.2;
  }

  .review-time {
    margin: 0.15rem 0 0;
    font-size: 0.82rem;
    color: var(--muted);
  }

  .review-text {
    margin: 0;
    flex: 1;
  }

  .review-text p {
    margin: 0;
    color: var(--text);
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 6;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .review-footer {
    margin-top: auto;
    padding-top: 0.25rem;
    border-top: 1px solid var(--border);
  }

  .review-translated-note {
    margin: 0 0 0.5rem;
    font-size: 0.75rem;
    color: var(--muted);
    font-style: italic;
  }

  .review-verified {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--muted);
    letter-spacing: 0.01em;
  }

  .google-g {
    flex-shrink: 0;
  }

  .reviews-nav {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--brand-dark);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    box-shadow: var(--shadow);
    transition: background 0.2s ease, color 0.2s ease;
  }

  .reviews-nav:hover {
    background: var(--brand);
    color: #fff;
  }

  .reviews-nav[hidden] {
    display: none;
  }

  .reviews-cta-wrap {
    text-align: center;
    margin: 1.75rem 0 0;
  }

  .reviews-cta {
    display: inline-flex;
  }

  @media (max-width: 640px) {
    .reviews-carousel {
      grid-template-columns: 1fr;
    }

    .reviews-nav {
      display: none;
    }
  }
</style>
