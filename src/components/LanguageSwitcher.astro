---
import type { Locale, PageKey } from "../i18n/config";
import { localeList, localePath } from "../i18n/config";
import { locales } from "../i18n/config";

interface Props {
  locale: Locale;
  page: PageKey;
}

const { locale, page } = Astro.props;
---

<div class="lang-switcher">
  <label class="lang-label" for="lang-select">
    <span class="lang-globe" aria-hidden="true">🌐</span>
    <span class="sr-only">Language</span>
  </label>
  <select id="lang-select" class="lang-select" aria-label="Select language">
    {localeList.map((loc) => (
      <option value={localePath(loc, page)} selected={loc === locale}>
        {locales[loc].flag} {locales[loc].label}
      </option>
    ))}
  </select>
</div>

<script>
  const select = document.getElementById("lang-select") as HTMLSelectElement | null;
  select?.addEventListener("change", () => {
    if (select.value) window.location.href = select.value;
  });
</script>

<style>
  .lang-switcher {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .lang-label {
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }

  .lang-globe {
    font-size: 1.15rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .lang-select {
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 0.4rem 0.6rem;
    font: inherit;
    background: white;
    color: var(--text);
    cursor: pointer;
    min-width: 10.5rem;
  }
</style>
