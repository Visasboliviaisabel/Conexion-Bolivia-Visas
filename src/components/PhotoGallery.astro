---
import type { Translations } from "../i18n/translations";

interface Props {
  gallery: Translations["home"]["gallery"];
  title: string;
  subtitle: string;
}

const { gallery, title, subtitle } = Astro.props;

const photos = [
  {
    src: "/images/gallery-office-entrance.jpg",
    width: 1024,
    height: 768,
    ...gallery.entrance,
    position: "center center",
  },
  {
    src: "/images/gallery-office-happy.jpg",
    width: 460,
    height: 614,
    ...gallery.happy,
    position: "center 28%",
  },
  {
    src: "/images/gallery-passports.jpg",
    width: 1024,
    height: 1024,
    ...gallery.passports,
    position: "center 42%",
  },
] as const;
---

<section class="section gallery-section">
  <div class="container gallery-header">
    <h2>{title}</h2>
    <p class="lead">{subtitle}</p>
  </div>

  <div class="gallery-row">
    {photos.map((photo) => (
      <figure class="gallery-card">
        <div class="gallery-image-wrap">
          <img
            src={photo.src}
            alt={photo.alt}
            width={photo.width}
            height={photo.height}
            loading="lazy"
            decoding="async"
            style={`object-position: ${photo.position};`}
          />
        </div>
        <figcaption>{photo.caption}</figcaption>
      </figure>
    ))}
  </div>
</section>

<style>
  .gallery-section {
    background: linear-gradient(180deg, var(--brand-pale) 0%, var(--bg) 100%);
  }

  .gallery-header {
    text-align: center;
    max-width: 52ch;
    margin-inline: auto;
  }

  .gallery-header .lead {
    margin-inline: auto;
  }

  .gallery-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
    width: min(1200px, calc(100% - 2rem));
    margin-inline: auto;
    margin-top: 2.25rem;
  }

  .gallery-card {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .gallery-image-wrap {
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    background: var(--surface);
    aspect-ratio: 4 / 3;
  }

  .gallery-card img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gallery-card figcaption {
    font-size: 0.9rem;
    color: var(--muted);
    text-align: center;
    line-height: 1.45;
    padding-inline: 0.25rem;
  }

  @media (max-width: 900px) {
    .gallery-row {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      max-width: 36rem;
    }
  }
</style>
