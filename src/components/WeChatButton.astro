---
import { localePath } from "../i18n/config";
import type { Locale } from "../i18n/config";

interface Props {
  locale: Locale;
  label: string;
}

const { locale, label } = Astro.props;
---

<a
  class="wechat-float"
  href={`${localePath(locale, "contact")}#wechat`}
  aria-label={label}
  data-analytics-event="wechat_click"
  data-analytics-label="floating_button"
>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28" fill="white" aria-hidden="true">
    <path d="M8.5 3C4.91 3 2 5.46 2 8.42c0 1.55.86 2.95 2.2 3.88L3.5 15.5l3.45-1.02c.64.18 1.32.28 2.02.28.08 0 .16 0 .24-.01-.14-.48-.22-.98-.22-1.5 0-2.96 2.91-5.36 6.5-5.36.22 0 .43.01.64.03C16.74 4.95 13.02 3 8.5 3zm-2.3 4.1c-.45 0-.82-.35-.82-.78s.37-.78.82-.78.82.35.82.78-.37.78-.82.78zm4.6 0c-.45 0-.82-.35-.82-.78s.37-.78.82-.78.82.35.82.78-.37.78-.82.78zM22 12.08c0-2.52-2.48-4.56-5.54-4.56-3.06 0-5.54 2.04-5.54 4.56s2.48 4.56 5.54 4.56c.58 0 1.14-.08 1.67-.22l2.83.84-.77-2.45c1.05-.82 1.71-2.01 1.71-3.33zm-7.38-1.02c-.36 0-.66-.28-.66-.62s.3-.62.66-.62.66.28.66.62-.3.62-.66.62zm3.68 0c-.36 0-.66-.28-.66-.62s.3-.62.66-.62.66.28.66.62-.3.62-.66.62z"/>
  </svg>
  <span class="wechat-label">{label}</span>
</a>

<style>
  .wechat-float {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 200;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: #07c160;
    color: white;
    padding: 0.85rem 1.1rem;
    border-radius: 999px;
    box-shadow: 0 4px 20px rgba(7, 193, 96, 0.45);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: transform 0.15s;
  }

  .wechat-float:hover {
    text-decoration: none;
    transform: scale(1.04);
  }

  html[dir="rtl"] .wechat-float {
    right: auto;
    left: 1.5rem;
  }

  @media (max-width: 480px) {
    .wechat-label { display: none; }
    .wechat-float { padding: 0.85rem; border-radius: 50%; }
  }
</style>
