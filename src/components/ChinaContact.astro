---
import { business } from "../data/business";
import type { ChinaContactCopy } from "../i18n/china-translations";

interface Props {
  copy: ChinaContactCopy;
}

const { copy } = Astro.props;
const { xiaohongshu, wechatId, wechatQrImage } = business.china;
const hasWechat = Boolean(wechatId || wechatQrImage);
---

<div class="wechat-banner" id="wechat">
  <h2>{copy.wechatTitle}</h2>
  {hasWechat ? (
    <>
      <p>{copy.wechatText}</p>
      <div class="wechat-banner-body">
        {wechatQrImage && (
          <img
            class="wechat-qr"
            src={wechatQrImage}
            alt="WeChat QR code for VisasBoliviaCusco"
            width="477"
            height="477"
            loading="lazy"
            decoding="async"
          />
        )}
        <div class="wechat-banner-actions">
          {wechatId && (
            <p class="wechat-id">
              <strong>{wechatId}</strong>
            </p>
          )}
          {wechatId && (
            <button
              class="button button-wechat"
              type="button"
              data-wechat-id={wechatId}
              data-analytics-event="wechat_click"
              data-analytics-label="copy_wechat_id"
            >
              {copy.wechatCta}
            </button>
          )}
        </div>
      </div>
    </>
  ) : (
    <p class="wechat-pending">{copy.wechatPending}</p>
  )}
</div>

<div class="xhs-banner">
  <h2>{copy.xhsTitle}</h2>
  <p>{copy.xhsText}</p>
  <a
    class="button button-xhs"
    href={xiaohongshu}
    target="_blank"
    rel="noopener noreferrer"
  >
    {copy.xhsCta}
  </a>
</div>

<script>
  document.querySelectorAll("[data-wechat-id]").forEach((button) => {
    button.addEventListener("click", async () => {
      const id = button.getAttribute("data-wechat-id");
      if (!id) return;
      const original = button.textContent ?? "";
      button.setAttribute("data-original-label", original);
      try {
        await navigator.clipboard.writeText(id);
        button.textContent = "✓";
        setTimeout(() => {
          button.textContent = button.getAttribute("data-original-label") ?? original;
        }, 2000);
      } catch {
        /* clipboard unavailable */
      }
    });
  });
</script>

<style>
  .wechat-banner {
    background: #ecfdf5;
    border: 1px solid #a7f3d0;
    border-radius: 1rem;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .wechat-banner h2 {
    margin-top: 0;
  }

  .wechat-banner p {
    color: var(--muted);
    max-width: 65ch;
  }

  .wechat-banner-body {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    margin-top: 1.25rem;
  }

  .wechat-qr {
    width: 200px;
    height: 200px;
    object-fit: contain;
    flex-shrink: 0;
    border-radius: 0.75rem;
    border: 1px solid var(--border);
    background: white;
    padding: 0.35rem;
  }

  .wechat-banner-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .button-wechat {
    background: #07c160;
    color: white;
    border: none;
    cursor: pointer;
    font: inherit;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 1.35rem;
    border-radius: 999px;
    font-weight: 600;
  }

  .wechat-id {
    margin: 0;
    color: var(--text) !important;
    font-size: 1.05rem;
  }

  .wechat-pending {
    font-style: italic;
    color: var(--muted);
  }

  .xhs-banner {
    background: #fff5f5;
    border: 1px solid #fecaca;
    border-radius: 1rem;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .xhs-banner h2 {
    margin-top: 0;
  }

  .xhs-banner p {
    color: var(--muted);
    max-width: 65ch;
    margin-bottom: 1.25rem;
  }

  .button-xhs {
    background: #ff2442;
    color: white;
    border: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 1.35rem;
    border-radius: 999px;
    font-weight: 600;
    text-decoration: none;
  }

  .button-xhs:hover {
    text-decoration: none;
    filter: brightness(0.95);
  }

  @media (max-width: 480px) {
    .wechat-banner-body {
      flex-direction: column;
      align-items: flex-start;
    }

    .wechat-qr {
      width: min(220px, 100%);
      height: auto;
      aspect-ratio: 1;
    }
  }
</style>
