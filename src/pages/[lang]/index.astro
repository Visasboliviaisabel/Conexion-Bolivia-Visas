---
import I18nLayout from "../../layouts/I18nLayout.astro";
import PhotoGallery from "../../components/PhotoGallery.astro";
import GoogleReviews from "../../components/GoogleReviews.astro";
import ContactPrimaryButton from "../../components/ContactPrimaryButton.astro";
import VisaChecker from "../../components/VisaChecker.astro";
import reviewsData from "../../data/reviews.json";
import type { GoogleReviewsData } from "../../data/reviews.types";
import NationalityLinks from "../../components/NationalityLinks.astro";
import { localeList, localePath } from "../../i18n/config";
import type { Locale } from "../../i18n/config";
import { getTranslations } from "../../i18n/translations";

export function getStaticPaths() {
  return localeList.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const t = getTranslations(locale);
const reviews = reviewsData as GoogleReviewsData;
---

<I18nLayout locale={locale} page="home">
  <section class="hero">
    <div class="container">
      <p class="eyebrow">{t.home.eyebrow}</p>
      <h1>{t.home.title}</h1>
      <p class="lead">{t.home.heroText}</p>
      <ul class="highlights">
        {t.home.highlights.map((item) => <li>{item}</li>)}
      </ul>
      <div class="button-row">
        <ContactPrimaryButton
          locale={locale}
          whatsappLabel={t.home.ctaWhatsapp}
          wechatLabel={t.china?.ctaWechat ?? t.home.ctaWhatsapp}
        />
        <a class="button button-outline" href={localePath(locale, "contact")}>{t.home.ctaContact}</a>
      </div>
    </div>
  </section>

  <VisaChecker locale={locale} />

  <section class="section">
    <div class="container split">
      <div>
        <h2>{t.home.requirementsTitle}</h2>
        <ul class="list-check">
          {t.home.requirements.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <div class="split-image-wrap split-image-wrap--landscape">
        <img src="/images/salar-sunset.png" alt="Tour vehicle on the Salar de Uyuni salt flats with sky reflection, Bolivia" loading="lazy" width="638" height="480" />
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container split">
      <div class="split-image-wrap split-image-wrap--portrait">
        <img src="/images/owner-standing.png" alt={t.home.salarImageAlt} loading="lazy" width="768" height="1024" />
      </div>
      <div>
        <h2>{t.home.salarTitle}</h2>
        <p>{t.home.salarText}</p>
        <div class="card faq-item">
          <h3>{t.home.faqQuestion}</h3>
          <p>{t.home.faqAnswer}</p>
        </div>
        <p style="margin-top: 1rem;">
          <a class="button button-secondary" href={localePath(locale, "guide")}>{t.nav.guide} →</a>
          {" "}
          <a class="button button-secondary" href={localePath(locale, "tours")}>{t.nav.tours} →</a>
        </p>
      </div>
    </div>
  </section>

  <PhotoGallery
    title={t.home.galleryTitle}
    subtitle={t.home.gallerySubtitle}
    gallery={t.home.gallery}
  />

  <GoogleReviews locale={locale} copy={t.reviews} data={reviews} />

  <section class="section">
    <div class="container">
      <h2>{t.home.servicesTitle}</h2>
      <p class="lead">{t.home.servicesSubtitle}</p>
      <div class="grid-3" style="margin-top: 1.5rem;">
        {t.home.serviceCards.map((card) => (
          <article class="card">
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
      <div class="button-row">
        <ContactPrimaryButton
          locale={locale}
          whatsappLabel={t.home.ctaWhatsapp}
          wechatLabel={t.china?.ctaWechat ?? t.home.ctaWhatsapp}
        />
        <a class="button button-secondary" href={localePath(locale, "services")}>{t.nav.services}</a>
      </div>
    </div>
  </section>

  <NationalityLinks locale={locale} />
</I18nLayout>
