---
import I18nLayout from "../../../layouts/I18nLayout.astro";
import ContactPrimaryButton from "../../../components/ContactPrimaryButton.astro";
import { localeList } from "../../../i18n/config";
import type { Locale } from "../../../i18n/config";
import type { NationalityId } from "../../../data/nationalities";
import { getNationalityPageContent } from "../../../i18n/nationality-page-content";
import { getTranslations } from "../../../i18n/translations";
import { nationalityPath, nationalityList, getNationalityLabel } from "../../../data/nationalities";
import { localePath } from "../../../i18n/config";
import { getVisaCheckerCopy } from "../../../i18n/visa-checker-translations";

export function getStaticPaths() {
  const paths: { params: { lang: string; country: string }; props: { nationalityId: NationalityId } }[] = [];

  for (const lang of localeList) {
    for (const id of nationalityList) {
      paths.push({
        params: { lang, country: nationalityPath(lang as Locale, id).split("/").filter(Boolean).slice(-1)[0]! },
        props: { nationalityId: id },
      });
    }
  }

  return paths;
}

const locale = Astro.params.lang as Locale;
const { nationalityId } = Astro.props;
const content = getNationalityPageContent(locale, nationalityId);
const t = getTranslations(locale);
const visaCopy = getVisaCheckerCopy(locale);
---

<I18nLayout locale={locale} page="nationality" nationalityId={nationalityId} faqSchema={content.faqs}>
  <section class="hero hero--subpage">
    <div class="container">
      <p class="eyebrow">{content.eyebrow}</p>
      <h1>{content.title}</h1>
      <p class="lead">{content.subtitle}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="nationality-group-card">
        <p class="nationality-group-card__label">{content.groupLabel}</p>
        <p class="nationality-group-card__text">{content.groupExplain}</p>
        {content.syncedAt && (
          <p class="nationality-group-card__sync">{visaCopy.disclaimer}</p>
        )}
      </div>
      <p class="lead">{content.intro}</p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2>{content.requirementsTitle}</h2>
      <ul class="list-check">
        {content.requirements.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  {content.showVisaProcess && (
    <section class="section">
      <div class="container">
        <h2>{content.processTitle}</h2>
        <div class="grid-3" style="margin-top: 1.5rem;">
          {content.processSteps.map((step, i) => (
            <article class="card">
              <p class="eyebrow">{i + 1}</p>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {content.showVisaProcess && (
    <section class="section section-alt">
      <div class="container">
        <h2>{content.whyCuscoTitle}</h2>
        <ul class="list-check">
          {content.whyCusco.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <section class="section">
    <div class="container">
      <h2>{content.faqTitle}</h2>
      {content.faqs.map((faq) => (
        <div class="card faq-item">
          <h3>{faq.q}</h3>
          <p>{faq.a}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="section section-alt">
    <div class="container whatsapp-banner">
      <h2>{content.ctaTitle}</h2>
      <p>{content.ctaText}</p>
      <div class="button-row">
        {!content.showVisaProcess && (
          <a class="button button-primary" href={content.travelPageHref}>{content.ctaTitle}</a>
        )}
        {content.showVisaProcess && (
          <ContactPrimaryButton
            locale={locale}
            whatsappLabel={t.home.ctaWhatsapp}
            wechatLabel={t.china?.ctaWechat ?? t.home.ctaWhatsapp}
          />
        )}
        <a class="button button-secondary" href={localePath(locale, "contact")}>{t.home.ctaContact}</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{content.relatedTitle}</h2>
      <ul class="nationality-related">
        {nationalityList.filter((id) => id !== nationalityId).map((id) => (
          <li><a href={nationalityPath(locale, id)}>{getNationalityLabel(id, locale)}</a></li>
        ))}
      </ul>
    </div>
  </section>
</I18nLayout>

<style>
  .nationality-group-card {
    margin-bottom: 1.5rem;
    padding: 1.25rem 1.5rem;
    border-radius: 1rem;
    background: var(--brand-pale);
    border: 1px solid color-mix(in srgb, var(--brand) 18%, transparent);
  }

  .nationality-group-card__label {
    margin: 0 0 0.35rem;
    font-weight: 700;
    color: var(--brand);
  }

  .nationality-group-card__text {
    margin: 0;
    font-size: 1.05rem;
  }

  .nationality-group-card__sync {
    margin: 0.75rem 0 0;
    font-size: 0.875rem;
    color: var(--text-muted, #5c6670);
  }

  .nationality-related {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
  }

  .nationality-related a {
    display: inline-flex;
    padding: 0.5rem 1rem;
    background: var(--brand-pale);
    border-radius: 999px;
    font-weight: 500;
    text-decoration: none;
  }
</style>
