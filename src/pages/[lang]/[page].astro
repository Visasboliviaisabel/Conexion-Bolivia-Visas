---
import I18nLayout from "../../layouts/I18nLayout.astro";
import ContactForm from "../../components/ContactForm.astro";
import ChinaContact from "../../components/ChinaContact.astro";
import ContactPrimaryButton from "../../components/ContactPrimaryButton.astro";
import { localeList, locales, localePath } from "../../i18n/config";
import type { Locale } from "../../i18n/config";
import { isChinaLocale } from "../../i18n/china-translations";
import { getTranslations } from "../../i18n/translations";
import { business } from "../../data/business";

export function getStaticPaths() {
  const paths: { params: { lang: string; page: string }; props: { pageType: "services" | "contact" | "guide" } }[] = [];

  for (const lang of localeList) {
    paths.push({
      params: { lang, page: locales[lang].slugs.services },
      props: { pageType: "services" },
    });
    paths.push({
      params: { lang, page: locales[lang].slugs.guide },
      props: { pageType: "guide" },
    });
    paths.push({
      params: { lang, page: locales[lang].slugs.contact },
      props: { pageType: "contact" },
    });
  }

  return paths;
}

const locale = Astro.params.lang as Locale;
const { pageType } = Astro.props;
const t = getTranslations(locale);
---

{pageType === "services" ? (
  <I18nLayout locale={locale} page="services">
    <section class="hero hero--subpage">
      <div class="container">
        <p class="eyebrow">{t.nav.services}</p>
        <h1>{t.services.title}</h1>
        <p class="lead">{t.services.subtitle}</p>
      </div>
    </section>

    <section class="section">
      <div class="container grid-3">
        {t.services.cards.map((card) => (
          <article class="card">
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section section-alt">
      <div class="container">
        <h2>{t.services.faqTitle}</h2>
        {t.services.faqs.map((faq) => (
          <div class="card faq-item">
            <h3>{faq.q}</h3>
            <p>{faq.a}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="container" style="text-align: center;">
        <ContactPrimaryButton
          locale={locale}
          whatsappLabel={t.home.ctaWhatsapp}
          wechatLabel={t.china?.ctaWechat ?? t.home.ctaWhatsapp}
        />
      </div>
    </section>
  </I18nLayout>
) : pageType === "guide" ? (
  <I18nLayout locale={locale} page="guide" faqSchema={t.guide.faqs}>
    <section class="hero hero--subpage">
      <div class="container">
        <p class="eyebrow">{t.nav.guide}</p>
        <h1>{t.guide.title}</h1>
        <p class="lead">{t.guide.subtitle}</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <p class="lead">{t.guide.intro}</p>
      </div>
    </section>

    <section class="section section-alt">
      <div class="container">
        <h2>{t.guide.stepsTitle}</h2>
        <div class="grid-3" style="margin-top: 1.5rem;">
          {t.guide.steps.map((step, i) => (
            <article class="card">
              <p class="eyebrow">{i + 1}</p>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2>{t.guide.faqTitle}</h2>
        {t.guide.faqs.map((faq) => (
          <div class="card faq-item">
            <h3>{faq.q}</h3>
            <p>{faq.a}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="section section-alt">
      <div class="container whatsapp-banner">
        <h2>{t.guide.ctaTitle}</h2>
        <p>{t.guide.ctaText}</p>
        <div class="button-row">
          <ContactPrimaryButton
            locale={locale}
            whatsappLabel={t.home.ctaWhatsapp}
            wechatLabel={t.china?.ctaWechat ?? t.home.ctaWhatsapp}
          />
          <a class="button button-secondary" href={localePath(locale, "contact")}>{t.home.ctaContact}</a>
        </div>
      </div>
    </section>
  </I18nLayout>
) : (
  <I18nLayout locale={locale} page="contact">
    <section class="section">
      <div class="container">
        <h1>{t.contact.title}</h1>
        <p class="lead">{t.contact.subtitle}</p>

        {isChinaLocale(locale) && t.china ? (
          <ChinaContact copy={t.china} />
        ) : (
          <div class="whatsapp-banner">
            <h2>{t.contact.whatsappTitle}</h2>
            <p>{t.contact.whatsappText}</p>
            <a class="button button-primary" href={business.whatsappUrl} target="_blank" rel="noopener noreferrer">
              {t.contact.whatsappCta}
            </a>
          </div>
        )}

        {isChinaLocale(locale) && (
          <div class="whatsapp-banner" style="margin-top: 1.5rem;">
            <h2>{t.contact.whatsappTitle}</h2>
            <p>{t.china?.whatsappNote ?? t.contact.whatsappText}</p>
            <a class="button button-secondary" href={business.whatsappUrl} target="_blank" rel="noopener noreferrer">
              {t.contact.whatsappCta}
            </a>
          </div>
        )}

        <div class="contact-layout">
          <div class="contact-main">
            <figure class="contact-feature-photo">
              <img
                src="/images/office-welcome.png"
                alt={t.contact.contactImageAlt}
                loading="lazy"
                decoding="async"
                width="768"
                height="1024"
              />
            </figure>

            <div class="panel">
              <h2>{t.contact.formTitle}</h2>
              <ContactForm
                labels={{
                  nameLabel: t.contact.nameLabel,
                  emailLabel: t.contact.emailLabel,
                  messageLabel: t.contact.messageLabel,
                  submitLabel: t.contact.submitLabel,
                  formSending: t.contact.formSending,
                  formSuccess: t.contact.formSuccess,
                  formError: t.contact.formError,
                }}
              />
            </div>
          </div>

          <aside class="contact-sidebar">
            <div class="card">
              <h3>{t.contact.locationTitle}</h3>
              <p>{t.contact.locationText}</p>
              <p>{business.address.full}</p>
              <p><a href={`tel:${business.phone}`}>{business.phone}</a></p>
              <p><a href={`mailto:${business.email}`}>{business.email}</a></p>
            </div>
            <div class="card">
              <h3>{t.contact.hoursTitle}</h3>
              <p>{t.contact.hoursWeekdays}</p>
              <p>{t.contact.hoursWeekends}</p>
            </div>
            <p>
              <a class="button button-secondary" href={business.mapsUrl} target="_blank" rel="noopener noreferrer">
                {t.contact.directionsCta}
              </a>
            </p>
            <iframe
              class="map-embed"
              src={business.mapsEmbed}
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Conexión Bolivia office location"
            />
          </aside>
        </div>
      </div>
    </section>
  </I18nLayout>
)}
